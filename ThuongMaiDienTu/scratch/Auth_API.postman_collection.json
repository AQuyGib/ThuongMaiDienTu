{
	"info": {
		"_postman_id": "8f8e02d6-444b-4b11-9a7f-d123456789ab",
		"name": "Auth API",
		"description": "Postman Collection for testing Login, Profile, and Logout APIs.\n\nInstructions:\n1. Set base_url variable if different (default is http://127.0.0.1:8000).\n2. Run Login request. The collection variable `bearer_token` will be populated automatically!\n3. Run Profile (Me) and Logout requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData && jsonData.token) {",
							"    pm.collectionVariables.set(\"bearer_token\", jsonData.token);",
							"    console.log(\"Saved bearer_token successfully: \" + jsonData.token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"admin@gmail.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v1/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"login"
					]
				},
				"description": "Submit email and password to receive a bearer session token. If login succeeds, the token is automatically saved into the collection's `bearer_token` variable."
			},
			"response": []
		},
		{
			"name": "Profile (Me)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v1/me",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"me"
					]
				},
				"description": "Retrieve currently authenticated user profile using the dynamic Bearer Token."
			},
			"response": []
		},
		{
			"name": "Logout",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v1/logout",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"logout"
					]
				},
				"description": "Revoke and delete the active bearer token from the database."
			},
			"response": []
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{bearer_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		},
		{
			"key": "bearer_token",
			"value": "replace_with_actual_token_received_from_login_response",
			"type": "string"
		}
	]
}
